        loader.style.display = 'none';
        content.style.display = 'block';
        
        // Usar el button_label del metadata si está disponible
        const metadata = result._metadata || {};
        const buttonLabel = metadata.button_label || (result.origen === "cache" ? "Análisis en caché" : "Nuevo análisis");
        
        if (result.origen === "cache") {
            btn.className = "btn btn-sm btn-info";
            btn.innerHTML = `<i class="fas fa-history me-2"></i>${buttonLabel}`;
        } else if (result.origen === "nuevo") {
            btn.className = "btn btn-sm btn-success";
            btn.innerHTML = `<i class="fas fa-sparkles me-2"></i>${buttonLabel}`;
        } else {
            btn.className = "btn btn-sm btn-outline-info";
            btn.innerHTML = '<i class="fas fa-magic me-2"></i>Solicitar Análisis';
        }


    } catch (err) {
        loader.style.display = 'none';
        errorDiv.style.display = 'block';
        errorDiv.innerText = "️ " + err.message;
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-sync me-2"></i>Reintentar';
    }
}

// Función para actualizar el historial de un jugador específico
async function actualizarHistorialJugador(puuid) {
    const btn = document.getElementById('btn-actualizar-historial');
    const statusDiv = document.getElementById('actualizacion-status');
    
    // Mostrar estado de carga
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Actualizando...';
    statusDiv.style.display = 'block';
    statusDiv.innerHTML = '<div class="alert alert-info"><i class="fas fa-info-circle me-2"></i>Solicitando actualización de historial...</div>';
    
    try {
        const response = await fetch(`/api/actualizar-jugador/${puuid}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        });
        
        const result = await response.json();
        
        if (!response.ok) {
            throw new Error(result.mensaje || result.error || 'Error al actualizar');
        }
        
        // Mostrar éxito
        statusDiv.innerHTML = `<div class="alert alert-success"><i class="fas fa-check-circle me-2"></i>${result.mensaje || 'Historial actualizado correctamente'}</div>`;
        
        // Recargar la página después de 2 segundos para mostrar los nuevos datos
        setTimeout(() => {
            window.location.reload();
        }, 2000);
        
    } catch (err) {
        statusDiv.innerHTML = `<div class="alert alert-danger"><i class="fas fa-exclamation-circle me-2"></i>Error: ${err.message}</div>`;
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Actualizar Historial';
    }
}</script>


