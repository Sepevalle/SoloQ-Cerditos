                                    { val: 400, color: '#cd7f32' },
                                    { val: 800, color: '#a9a9a9' },
                                    { val: 1200, color: '#daa520' },
                                    { val: 1600, color: '#20b2aa' },
                                    { val: 2000, color: '#2ecc71' },
                                    { val: 2400, color: '#3498db' },
                                    { val: 2800, color: '#9b59b6' },
                                    { val: 3000, color: '#e74c3c' },
                                    { val: 3200, color: '#f1c40f' }
                                ];

                                tiers.forEach(tier => {
                                    gradient.addColorStop(tier.val / 3200, hexToRgba(tier.color, 0.2));
                                });

                                return gradient;
                            },
                            borderWidth: 2,
                            pointRadius: 3,
                            pointHoverRadius: 5,
                            fill: true,
                            tension: 0.3,
                            segment: {
                                borderColor: ctx => getTierColor(ctx.p0.parsed.y)
                            },
                            pointBackgroundColor: ctx => getTierColor(ctx.parsed.y),
                            pointBorderColor: ctx => getTierColor(ctx.parsed.y)
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                mode: 'index',
                                intersect: false,
                                callbacks: {
                                    label: function(context) {
                                        return formatElo(context.raw);
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                display: false,
                                grid: { display: false }
                            },
                            y: {
                                grid: { color: gridColor },
                                ticks: { 
                                    color: textColor,
                                    stepSize: 100,
                                    callback: function(value) {
                                        if (value % 100 !== 0) return null;

                                        if (value >= 2800) {
                                            const lps = value - 2800;
                                            if (value >= 3200) return `CHALLENGER`;
                                            if (value >= 3000) return `GM`;
                                            return `MASTER ${lps}LP`;
                                        }

                                        const tiers = ["HIERRO", "BRONCE", "PLATA", "ORO", "PLATINO", "ESMERALDA", "DIAMANTE"];
                                        const ranks = ["IV", "III", "II", "I"];
                                        
                                        const tierIndex = Math.floor(value / 400);
                                        const rankIndex = Math.floor((value % 400) / 100);
                                        
                                        if (tiers[tierIndex]) {
                                            return `${tiers[tierIndex]} ${ranks[rankIndex]}`;
                                        }
                                        return "";
                                    }
                                }
                            }
                        },
                        interaction: {
                            mode: 'nearest',
                            axis: 'x',
                            intersect: false
                        }
                    }
                });
            } else {
                ctx.style.display = 'none';
                const container = ctx.parentElement;
                const msg = document.createElement('p');
                msg.textContent = "Insuficientes datos para el gráfico de Elo.";
