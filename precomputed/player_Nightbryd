                    const tiers = ["HIERRO", "BRONCE", "PLATA", "ORO", "PLATINO", "ESMERALDA", "DIAMANTE"];
                    const ranks = ["IV", "III", "II", "I"];
                    
                    const tierIndex = Math.floor(value / 400);
                    const rankIndex = Math.floor((value % 400) / 100);
                    const lp = Math.round(value % 100);
                    
                    const tier = tiers[tierIndex] || "UNKNOWN";
                    const rank = ranks[rankIndex] || "";
                    return `${tier} ${rank} (${lp} LP)`;
                };

                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Elo (Valor Clasificación)',
                            data: dataPoints,
                            backgroundColor: function(context) {
                                const chart = context.chart;
                                const {ctx, chartArea, scales} = chart;
                                if (!chartArea) return null;
                                const yScale = scales.y;
                                if (!yScale) return null;

                                // Definir el gradiente basado en los valores absolutos de Elo (0 a 3200)
                                const yStart = yScale.getPixelForValue(0);
                                const yEnd = yScale.getPixelForValue(3200);
                                
                                const gradient = ctx.createLinearGradient(0, yStart, 0, yEnd);
                                
                                const tiers = [
                                    { val: 0, color: '#7a7a7a' },      // IRON
                                    { val: 400, color: '#cd7f32' },    // BRONZE
                                    { val: 800, color: '#a9a9a9' },    // SILVER
                                    { val: 1200, color: '#daa520' },   // GOLD
                                    { val: 1600, color: '#20b2aa' },   // PLATINUM
                                    { val: 2000, color: '#2ecc71' },   // EMERALD
                                    { val: 2400, color: '#3498db' },   // DIAMOND
                                    { val: 2800, color: '#9b59b6' },   // MASTER
                                    { val: 3000, color: '#e74c3c' },   // GRANDMASTER
                                    { val: 3200, color: '#f1c40f' }    // CHALLENGER
                                ];

                                tiers.forEach(tier => {
                                    gradient.addColorStop(tier.val / 3200, hexToRgba(tier.color, 0.2));
                                });

                                return gradient;
                            },
                            borderWidth: 2,
                            pointRadius: 3,
                            pointHoverRadius: 5,
                            fill: true,
                            tension: 0.3, // Suavizado de línea
                            segment: {
                                borderColor: ctx => getTierColor(ctx.p0.parsed.y)
                            },
                            pointBackgroundColor: ctx => getTierColor(ctx.parsed.y),
                            pointBorderColor: ctx => getTierColor(ctx.parsed.y)
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                mode: 'index',
                                intersect: false,
                                callbacks: {
                                    label: function(context) {
                                        return formatElo(context.raw);
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                display: false, // Ocultar fechas en eje X para limpieza
                                grid: { display: false }
