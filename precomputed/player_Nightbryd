                            y: {
                                grid: { color: gridColor },
                                ticks: { 
                                    color: textColor,
                                    stepSize: 100, // Forzar líneas cada división (100 LP)
                                    callback: function(value) {
                                        // Solo mostrar etiqueta si es una división exacta (0 LP)
                                        if (value % 100 !== 0) return null;

                                        if (value >= 2800) {
                                            const lps = value - 2800;
                                            if (value >= 3200) return `CHALLENGER`;
                                            if (value >= 3000) return `GM`;
                                            return `MASTER ${lps}LP`;
                                        }

                                        const tiers = ["HIERRO", "BRONCE", "PLATA", "ORO", "PLATINO", "ESMERALDA", "DIAMANTE"];
                                        const ranks = ["IV", "III", "II", "I"];
                                        
                                        const tierIndex = Math.floor(value / 400);
                                        const rankIndex = Math.floor((value % 400) / 100);
                                        
                                        if (tiers[tierIndex]) {
                                            return `${tiers[tierIndex]} ${ranks[rankIndex]}`;
                                        }
                                        return "";
                                    }
                                }
                            }
                        },
                        interaction: {
                            mode: 'nearest',
                            axis: 'x',
                            intersect: false
                        }
                    }
                });
            } else {
                // Si no hay suficientes datos, mostrar mensaje o ocultar
                ctx.style.display = 'none';
                const container = ctx.parentElement;
                const msg = document.createElement('p');
                msg.textContent = "Insuficientes datos para el gráfico de Elo.";
                msg.className = "text-muted small text-center mt-4";
                container.appendChild(msg);
