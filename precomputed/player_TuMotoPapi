                const formatElo = (value) => {
                    if (value >= 2800) {
                        const lps = value - 2800;
                        if (value >= 3200) return `CHALLENGER (${lps} LP)`;
                        if (value >= 3000) return `GRANDMASTER (${lps} LP)`;
                        return `MASTER (${lps} LP)`;
