                    const ranks = ["IV", "III", "II", "I"];
                    
                    const tierIndex = Math.floor(value / 400);
                    const rankIndex = Math.floor((value % 400) / 100);
                    const lp = Math.round(value % 100);
                    
                    const tier = tiers[tierIndex] || "UNKNOWN";
                    const rank = ranks[rankIndex] || "";
                    return `${tier} ${rank} (${lp} LP)`;
                };

