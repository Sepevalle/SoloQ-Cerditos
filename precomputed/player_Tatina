                                        if (tiers[tierIndex]) {
                                            return `${tiers[tierIndex]} ${ranks[rankIndex]}`;
                                        }
                                        return "";
                                    }
                                }
                            }
                        },
                        interaction: {
                            mode: 'nearest',
                            axis: 'x',
                            intersect: false
                        }
                    }
