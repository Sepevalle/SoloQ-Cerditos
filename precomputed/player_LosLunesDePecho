        // Banner dynamic images (if needed, this logic seems specific)
        const bannerImg = document.getElementById('banner-img');
        const banners = [
            "https://raw.githubusercontent.com/Sepevalle/SoloQ-Cerditos/refs/heads/main/banners/Banner5.png"
