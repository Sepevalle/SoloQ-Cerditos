            const elo = el.alt.toUpperCase();
            if (imagenesElo[elo]) el.src = imagenesElo[elo];
        });

        const toggleModeBtn = document.getElementById('toggle-mode');
        const body = document.body;


        if (localStorage.getItem('darkMode') === 'enabled') {
            body.classList.add('dark-mode');
            toggleModeBtn.textContent = 'Modo Claro';
        } else {
            toggleModeBtn.textContent = 'Modo Oscuro';
        }

        toggleModeBtn.addEventListener('click', function() {
            body.classList.toggle('dark-mode');
            if (body.classList.contains('dark-mode')) {
                toggleModeBtn.textContent = 'Modo Claro';
                localStorage.setItem('darkMode', 'enabled');
            } else {
                toggleModeBtn.textContent = 'Modo Oscuro';
                localStorage.setItem('darkMode', 'disabled');
            }
        });

        // Banner dynamic images (if needed, this logic seems specific)
        const bannerImg = document.getElementById('banner-img');
        const banners = [
            "https://raw.githubusercontent.com/Sepevalle/SoloQ-Cerditos/refs/heads/main/banners/Banner5.png"
        ];
        let currentBannerIndex = 0;

        function mostrarAnalisisIA(jsonResponse) {
            const d = jsonResponse.data;
            
            // Asignar textos
            document.getElementById('ia-individual').innerText = d.analisis_individual;
            document.getElementById('ia-companeros').innerText = d.valoracion_companeros;
            document.getElementById('ia-rivales').innerText = d.valoracion_rivales;
            document.getElementById('ia-mejora').innerText = d.aspectos_mejora;
            document.getElementById('ia-fuertes').innerText = d.puntos_fuertes; 
            document.getElementById('ia-recomendacion').innerText = d.recomendaciones;

            // Mostrar fecha si existe
            if(jsonResponse.timestamp) {
                const fecha = new Date(jsonResponse.timestamp * 1000).toLocaleString();
                document.getElementById('ia-timestamp').innerText = "Actualizado: " + fecha;
            }
        };


        function changeBanner() {
            currentBannerIndex = (currentBannerIndex + 1) % banners.length;
            bannerImg.src = banners[currentBannerIndex];
        }
        setInterval(changeBanner, 5000); // Change banner every 5 seconds

        // Lateral images dynamic (also specific to your design)
        const leftBanner = document.getElementById('left-banner');
        const rightBanner = document.getElementById('right-banner');
       const lateralBanners = [
            "https://raw.githubusercontent.com/Sepevalle/SoloQ-Cerditos/main/bannerlateral/1.jpg",
            "https://raw.githubusercontent.com/Sepevalle/SoloQ-Cerditos/main/bannerlateral/2.jpg",
            "https://raw.githubusercontent.com/Sepevalle/SoloQ-Cerditos/main/bannerlateral/3.jpg",
            "https://raw.githubusercontent.com/Sepevalle/SoloQ-Cerditos/main/bannerlateral/4.jpg",
            "https://raw.githubusercontent.com/Sepevalle/SoloQ-Cerditos/main/bannerlateral/5.jpg"
        ];
        let currentLateralBannerIndex = 0;

        function changeLateralBanner() {
            currentLateralBannerIndex = (currentLateralBannerIndex + 1) % lateralBanners.length;
            leftBanner.src = lateralBanners[currentLateralBannerIndex];
            rightBanner.src = lateralBanners[currentLateralBannerIndex];
        }
        setInterval(changeLateralBanner, 5000); // Change lateral banners every 5 seconds


        // Audio control
        const backgroundAudio = document.getElementById('backgroundAudio');
        const toggleAudioBtn = document.getElementById('toggleAudio');
        const muteIcon = document.getElementById('muteIcon');
        const volumeSlider = document.getElementById('volumeSlider');

        // Initialize audio state from localStorage
        const savedVolume = localStorage.getItem('backgroundAudioVolume');
        if (savedVolume !== null) {
            backgroundAudio.volume = parseFloat(savedVolume);
            volumeSlider.value = parseFloat(savedVolume);
        } else {
            backgroundAudio.volume = 1.0; // Default volume
            volumeSlider.value = 1.0;
        }

        const savedMuteState = localStorage.getItem('backgroundAudioMuted');
        if (savedMuteState === 'true') {
            backgroundAudio.muted = true;
            muteIcon.classList.remove('fa-volume-up');
            muteIcon.classList.add('fa-microphone-slash');
        } else {
            backgroundAudio.muted = false;
            // Attempt to play only if not muted, and handle Autoplay Policy
            const playPromise = backgroundAudio.play();
            if (playPromise !== undefined) {
                playPromise.catch(error => {
                    // Autoplay was prevented. Show a "play" button.
                    console.log("Autoplay prevented:", error);
                    muteIcon.classList.remove('fa-volume-up');
                    muteIcon.classList.add('fa-microphone-slash'); // Show muted icon as initial state
                    toggleAudioBtn.title = "Reproducir Música";
                });
            }
        }

        toggleAudioBtn.addEventListener('click', function() {
            backgroundAudio.muted = !backgroundAudio.muted;
            if (backgroundAudio.muted) {
                muteIcon.classList.remove('fa-volume-up');
                muteIcon.classList.add('fa-microphone-slash');
                toggleAudioBtn.title = "Desmutear Música";
                localStorage.setItem('backgroundAudioMuted', 'true');
            } else {
                muteIcon.classList.remove('fa-microphone-slash');
                muteIcon.classList.add('fa-volume-up');
                toggleAudioBtn.title = "Mutear Música";
                const playPromise = backgroundAudio.play();
                if (playPromise !== undefined) {
                    playPromise.catch(error => {
                        console.log("Play prevented after unmute:", error);
                    });
                }
                localStorage.setItem('backgroundAudioMuted', 'false');
            }
        });

        volumeSlider.addEventListener('input', function() {
            backgroundAudio.volume = this.value;
            localStorage.setItem('backgroundAudioVolume', this.value);
            if (this.value > 0 && backgroundAudio.muted) {
                backgroundAudio.muted = false;
                muteIcon.classList.remove('fa-microphone-slash');
                muteIcon.classList.add('fa-volume-up');
                toggleAudioBtn.title = "Mutear Música";
                localStorage.setItem('backgroundAudioMuted', 'false');
            } else if (this.value == 0 && !backgroundAudio.muted) {
                backgroundAudio.muted = true;
                muteIcon.classList.remove('fa-volume-up');
                muteIcon.classList.add('fa-microphone-slash');
                toggleAudioBtn.title = "Desmutear Música";
                localStorage.setItem('backgroundAudioMuted', 'true');
            }
        });

        const queueFilterControl = document.getElementById('queueFilter');
        const championFilterControl = document.getElementById('championFilter');
        const matchFiltersForm = document.getElementById('matchFiltersForm');
        const pageInput = document.getElementById('pageInput');

        [queueFilterControl, championFilterControl].forEach(control => {
            if (!control || !matchFiltersForm) {
                return;
            }

            control.addEventListener('change', () => {
                if (pageInput) {
                    pageInput.value = '1';
                }
                matchFiltersForm.submit();
            });
        });

        const paginationLabel = document.querySelector('#pagination-controls span.page-link');
        if (paginationLabel) {
            paginationLabel.textContent = 'Pagina 1 de 23';
        }

        return;

        // --- INICIO: LGICA DE FILTRADO Y PAGINACIN (REESTRUCTURADA) ---
        const queueFilter = document.getElementById('queueFilter');
        const championFilter = document.getElementById('championFilter');
        const allMatchRows = document.querySelectorAll('.match-history-table tbody tr');
        const paginationControls = document.getElementById('pagination-controls');
        const rowsPerPage = 10; // Partidas por página

        // --- ESTADO ---
        let currentPage = 1;

        // --- FUNCIONES AUXILIARES ---
        function populateChampionFilter() {
            // Usamos un Set para evitar campeones duplicados
            const championNames = new Set();
            allMatchRows.forEach(row => {
                // Solo consideramos las filas de partidas principales, no las de detalles
                if (row.dataset.championName) {
                    championNames.add(row.dataset.championName);
                }
            });

            championFilter.innerHTML = '<option value="all">Todos</option>';
            // Convertimos el Set a un Array y lo ordenamos alfabéticamente
            const sortedChampionNames = Array.from(championNames).sort();
            sortedChampionNames.forEach(championName => {
                championFilter.add(new Option(championName, championName));
            });
        }

        function populateQueueFilter() {
            // Usamos un Map para asociar ID de cola con su nombre, evitando duplicados
            const queueTypes = new Map();
            allMatchRows.forEach(row => {
                // Solo consideramos las filas de partidas principales
                if (row.dataset.queueId) {
                    const queueId = row.dataset.queueId;
                    // CORRECCIN: El nombre de la cola está en la primera celda (índice 0)
                    const queueName = row.cells[0].textContent.trim(); 
                    if (!queueTypes.has(queueId)) {
                        queueTypes.set(queueId, queueName);
                    }
                }
            });

            queueFilter.innerHTML = '<option value="all">Todas</option>';
            // Ordenamos las colas por nombre para una mejor UX
            const sortedQueues = Array.from(queueTypes.entries()).sort((a, b) => a[1].localeCompare(b[1]));
            sortedQueues.forEach(([queueId, queueName]) => queueFilter.add(new Option(queueName, queueId)));
        }

        function setupPagination(totalRows, page) {
            paginationControls.innerHTML = "";
            const pageCount = Math.ceil(totalRows / rowsPerPage) || 1; // Aseguramos que al menos sea 1
            if (pageCount <= 1) return;

            // Botón "Anterior"
            const prevLi = document.createElement('li');
            prevLi.className = `page-item ${page === 1 ? 'disabled' : ''}`;
            prevLi.innerHTML = `<a class="page-link" href="#" data-page="${page - 1}" aria-label="Previous">&laquo; Anterior</a>`;
            paginationControls.appendChild(prevLi);

            // Indicador de página "Página X de Y"
            const pageInfoLi = document.createElement('li');
            pageInfoLi.className = 'page-item disabled';
            pageInfoLi.innerHTML = `<span class="page-link">Página ${page} de ${pageCount}</span>`; // Más claro para el usuario
            paginationControls.appendChild(pageInfoLi);

            // Botón "Siguiente"
            const nextLi = document.createElement('li');
            nextLi.className = `page-item ${page === pageCount ? 'disabled' : ''}`;
            nextLi.innerHTML = `<a class="page-link" href="#" data-page="${page + 1}" aria-label="Next">Siguiente &raquo;</a>`;
            paginationControls.appendChild(nextLi);
        }

        // --- FUNCIN DE RENDERIZADO PRINCIPAL ---
        function renderMatchHistory() {
            const selectedQueue = queueFilter.value;
            const selectedChampion = championFilter.value;

            // 1. Obtener y filtrar las filas de partidas principales
            const mainMatchRows = Array.from(allMatchRows).filter(row => row.hasAttribute('data-queue-id'));
            const filteredMainRows = mainMatchRows.filter(row => {
                const queueMatch = (selectedQueue === 'all' || row.dataset.queueId === selectedQueue);
                const championMatch = (selectedChampion === 'all' || row.dataset.championName === selectedChampion);
                return queueMatch && championMatch;
            });

            // 2. Configurar la paginación basado en los resultados filtrados
            setupPagination(filteredMainRows.length, currentPage);

            // 3. Determinar qué filas mostrar en la página actual
            const startIndex = (currentPage - 1) * rowsPerPage;
            const endIndex = startIndex + rowsPerPage;
            const rowsForCurrentPage = filteredMainRows.slice(startIndex, endIndex);

            // 4. Iterar sobre TODAS las filas principales para establecer su visibilidad
            mainMatchRows.forEach(row => {
                const detailRow = row.nextElementSibling;

                if (rowsForCurrentPage.includes(row)) {
                    // Esta fila está en la página actual, así que la mostramos.
                    // No tocamos el 'display' de la fila de detalles para no interferir con la animación.
                    row.style.display = '';
                } else {
                    // Esta fila NO está en la página actual, la ocultamos junto con su detalle.
                    row.style.display = 'none';
                    if (detailRow && detailRow.id.startsWith('match-')) {
                        detailRow.style.display = 'none';
                    }
                }
            });
        }

        // --- EVENT LISTENERS ---
        queueFilter.addEventListener('change', () => {
            currentPage = 1; // Resetear a la primera página al cambiar el filtro
            renderMatchHistory();
        });
        championFilter.addEventListener('change', () => {
            currentPage = 1; // Resetear a la primera página al cambiar el filtro
            renderMatchHistory();
        });

        paginationControls.addEventListener('click', (e) => {
            e.preventDefault();
            const target = e.target.closest('.page-link');
            if (!target || target.parentElement.classList.contains('disabled') || target.parentElement.classList.contains('active')) return;

            const newPage = parseInt(target.dataset.page, 10);
            if (newPage !== currentPage) {
                currentPage = newPage;
                renderMatchHistory();
            }
        });

        

        // --- INICIALIZACIN ---
        populateQueueFilter();
        populateChampionFilter();
        renderMatchHistory();
        // --- FIN: LGICA DE FILTRADO Y PAGINACIN ---
    });

async function ejecutarAnalisisIA() {
    const puuid = "hzDcKRZIMVqhTC1eKOBSYhfGQHjNAC4x6r33gMoGGCOi_AaP11QGvTNCofCk5IyDYiPmKcp0a87jqw";
    const btn = document.getElementById('btn-ia');
    const loader = document.getElementById('ia-loader');
    const content = document.getElementById('ia-content');
    const errorDiv = document.getElementById('ia-error');

    // Resetear vista
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Analizando...';
    loader.style.display = 'block';
    content.style.display = 'none';
    errorDiv.style.display = 'none';

    try {
        const response = await fetch(`/api/analisis-ia/${puuid}`);
        const result = await response.json();

        if (!response.ok) throw new Error(result.mensaje || result.error || "Error");

        const d = result.data || result;

        // 1. Campos principales
        document.getElementById('ia-ind').innerText = d.analisis_individual;
        document.getElementById('ia-mejora').innerText = d.aspectos_mejora;
        document.getElementById('ia-recom').innerText = d.recomendaciones;
        document.getElementById('ia-fuertes').innerText = d.puntos_fuertes;

        // 2. Integrar Compañeros y Rivales
        document.getElementById('ia-extra').innerHTML = 
            `<strong>Aliados:</strong> ${d.valoracion_companeros}<br><br><strong>Rivales:</strong> ${d.valoracion_rivales}`;

        // 3. Campo 'Otros' abajo
        document.getElementById('ia-footer-otros').innerHTML = 
            `<i class="fas fa-info-circle me-1"></i> ${d.otros || "Sin notas adicionales"}`;

        // 4. Lógica de botón y visualización basada en origen
        loader.style.display = 'none';
        content.style.display = 'block';
        
        // Usar el button_label del metadata si está disponible
        const metadata = result._metadata || {};
        const buttonLabel = metadata.button_label || (result.origen === "cache" ? "Análisis en caché" : "Nuevo análisis");
        
        if (result.origen === "cache") {
            btn.className = "btn btn-sm btn-info";
            btn.innerHTML = `<i class="fas fa-history me-2"></i>${buttonLabel}`;
        } else if (result.origen === "nuevo") {
            btn.className = "btn btn-sm btn-success";
            btn.innerHTML = `<i class="fas fa-sparkles me-2"></i>${buttonLabel}`;
        } else {
            btn.className = "btn btn-sm btn-outline-info";
            btn.innerHTML = '<i class="fas fa-magic me-2"></i>Solicitar Análisis';
        }


    } catch (err) {
        loader.style.display = 'none';
        errorDiv.style.display = 'block';
        errorDiv.innerText = "️ " + err.message;
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-sync me-2"></i>Reintentar';
    }
}

// Función para actualizar el historial de un jugador específico
async function actualizarHistorialJugador(puuid) {
    const btn = document.getElementById('btn-actualizar-historial');
    const statusDiv = document.getElementById('actualizacion-status');
    
    // Mostrar estado de carga
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Actualizando...';
    statusDiv.style.display = 'block';
    statusDiv.innerHTML = '<div class="alert alert-info"><i class="fas fa-info-circle me-2"></i>Solicitando actualización de historial...</div>';
    
    try {
        const response = await fetch(`/api/actualizar-jugador/${puuid}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        });
        
        const result = await response.json();
        
        if (!response.ok) {
            throw new Error(result.mensaje || result.error || 'Error al actualizar');
        }
        
        // Mostrar éxito
        statusDiv.innerHTML = `<div class="alert alert-success"><i class="fas fa-check-circle me-2"></i>${result.mensaje || 'Historial actualizado correctamente'}</div>`;
        
        // Recargar la página después de 2 segundos para mostrar los nuevos datos
        setTimeout(() => {
            window.location.reload();
        }, 2000);
        
    } catch (err) {
        statusDiv.innerHTML = `<div class="alert alert-danger"><i class="fas fa-exclamation-circle me-2"></i>Error: ${err.message}</div>`;
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Actualizar Historial';
    }
}</script>


