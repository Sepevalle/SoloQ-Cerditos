<script>
    // --- INICIO: Gráfico de Elo ---
    document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('soloqEloChart');
        if (ctx) {
            // Obtener datos pasados desde Flask
            const eloHistory = [{"elo": 413, "timestamp": 1768952162698}];
            
            if (eloHistory && eloHistory.length > 1) {
                const labels = eloHistory.map(entry => {
                    const date = new Date(entry.timestamp);
                    return date.toLocaleDateString() + ' ' + date.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                });
                const dataPoints = eloHistory.map(entry => entry.elo);

                // Detectar modo oscuro para colores
                const isDarkMode = document.body.classList.contains('dark-mode');
                const gridColor = isDarkMode ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0, 0, 0, 0.1)';
                const textColor = isDarkMode ? '#adb5bd' : '#666';

                // Función para obtener el color según el Tier
                const getTierColor = (value) => {
                    if (value >= 2800) {
                        if (value >= 3200) return '#f1c40f'; // CHALLENGER - Dorado brillante
                        if (value >= 3000) return '#e74c3c'; // GRANDMASTER - Rojo
                        return '#9b59b6'; // MASTER - Morado
                    }
                    const tierIndex = Math.floor(value / 400);
                    switch (tierIndex) {
                        case 0: return '#7a7a7a'; // IRON - Gris
                        case 1: return '#cd7f32'; // BRONZE - Bronce
                        case 2: return '#a9a9a9'; // SILVER - Plata
                        case 3: return '#daa520'; // GOLD - Dorado
                        case 4: return '#20b2aa'; // PLATINUM - Turquesa
                        case 5: return '#2ecc71'; // EMERALD - Verde Esmeralda
                        case 6: return '#3498db'; // DIAMOND - Azul
                        default: return '#007bff'; // Fallback
                    }
                };

                // Helper para convertir hex a rgba con opacidad
                const hexToRgba = (hex, alpha) => {
                    const r = parseInt(hex.slice(1, 3), 16);
                    const g = parseInt(hex.slice(3, 5), 16);
                    const b = parseInt(hex.slice(5, 7), 16);
                    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
                };

                // Función para formatear el valor numérico a Rango (Ej: Oro I 50 LP)
                const formatElo = (value) => {
                    if (value >= 2800) {
                        const lps = value - 2800;
                        if (value >= 3200) return `CHALLENGER (${lps} LP)`;
                        if (value >= 3000) return `GRANDMASTER (${lps} LP)`;
                        return `MASTER (${lps} LP)`;
                    }
                    const tiers = ["HIERRO", "BRONCE", "PLATA", "ORO", "PLATINO", "ESMERALDA", "DIAMANTE"];
                    const ranks = ["IV", "III", "II", "I"];
                    
                    const tierIndex = Math.floor(value / 400);
                    const rankIndex = Math.floor((value % 400) / 100);
                    const lp = Math.round(value % 100);
                    
                    const tier = tiers[tierIndex] || "UNKNOWN";
                    const rank = ranks[rankIndex] || "";
                    return `${tier} ${rank} (${lp} LP)`;
                };

                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Elo (Valor Clasificación)',
                            data: dataPoints,
                            backgroundColor: function(context) {
                                const chart = context.chart;
                                const {ctx, chartArea, scales} = chart;
                                if (!chartArea) return null;
